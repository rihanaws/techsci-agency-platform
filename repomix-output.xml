            <option value="awaiting_onboarding">awaiting_onboarding</option>
            <option value="routing_failed">routing_failed</option>
          </select>
          {isUpdating && (
            <svg className="h-3 w-3 animate-spin text-[#4f98a3]" viewBox="0 0 24 24" fill="none">
